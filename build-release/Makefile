	$(MAKE) $(MAKESILENT) -f CMakeFiles/analyzer.dir/build.make CMakeFiles/analyzer.dir/src/tool_finder.c.o
.PHONY : src/tool_finder.c.o

src/tool_finder.i: src/tool_finder.c.i
.PHONY : src/tool_finder.i

# target to preprocess a source file
src/tool_finder.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/analyzer.dir/build.make CMakeFiles/analyzer.dir/src/tool_finder.c.i
.PHONY : src/tool_finder.c.i

src/tool_finder.s: src/tool_finder.c.s
.PHONY : src/tool_finder.s

# target to generate assembly for a file
src/tool_finder.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/analyzer.dir/build.make CMakeFiles/analyzer.dir/src/tool_finder.c.s
.PHONY : src/tool_finder.c.s

